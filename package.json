{
  "name": "@joshualevy029/tiptap-editor",
  "version": "0.1.2",
  "description": "Rich-text editor component built with Tiptap and Material UI.",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "vite --config playground/vite.config.ts",
    "build": "vite build",
    "build:playground": "vite build --config playground/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p playground/tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^9.2.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@tiptap/extension-bold": "^3.27.3",
    "@tiptap/extension-code-block": "^3.27.3",
    "@tiptap/extension-heading": "^3.27.3",
    "@tiptap/extension-highlight": "^3.27.3",
    "@tiptap/extension-image": "^3.27.3",
    "@tiptap/extension-italic": "^3.27.3",
    "@tiptap/extension-list": "^3.27.3",
    "@tiptap/extension-mathematics": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-strike": "^3.27.3",
    "@tiptap/extension-subscript": "^3.27.3",
    "@tiptap/extension-superscript": "^3.27.3",
    "@tiptap/extension-table": "^3.27.3",
    "@tiptap/extension-text-align": "^3.27.3",
    "@tiptap/extension-text-style": "^3.27.3",
    "@tiptap/extension-underline": "^3.27.3",
    "@tiptap/extensions": "^3.27.3",
    "@tiptap/markdown": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "katex": "^0.17.0",
    "mathlive": "^0.110.0"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^9.2.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^27.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.0.0"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoshuaLevy029/tiptap-editor.git"
  },
  "bugs": {
    "url": "https://github.com/JoshuaLevy029/tiptap-editor/issues"
  },
  "homepage": "https://github.com/JoshuaLevy029/tiptap-editor#readme",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  }
}
